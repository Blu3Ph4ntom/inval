---
import DocsLayout from '../../layouts/DocsLayout.astro'
import DocsSidebar from '../../components/docs/DocsSidebar.astro'
import DocsToc from '../../components/docs/DocsToc.astro'
import CodeBlock from '../../components/docs/CodeBlock.astro'
import Callout from '../../components/docs/Callout.astro'

const currentPage = '/docs/api-reference'

const headings = [
  { id: 'input', text: 'input()', level: 2 },
  { id: 'node', text: 'node()', level: 2 },
  { id: 'batch', text: 'batch()', level: 2 },
  { id: 'why', text: 'why()', level: 2 },
  { id: 'ancestors-descendants', text: 'ancestors() / descendants()', level: 2 },
  { id: 'todot', text: 'toDot()', level: 2 },
  { id: 'stats', text: 'stats()', level: 2 },
  { id: 'types', text: 'TypeScript Types', level: 2 },
]
---

<DocsLayout title="API Reference — Inval Docs" description="Complete API reference for all Inval functions and types.">
  <DocsSidebar slot="sidebar" currentPage={currentPage} />
  <DocsToc slot="toc" headings={headings} />

  <div class="doc-page">
    <nav class="breadcrumb">
      <a href="/docs/">Docs</a>
      <span class="bc-sep">/</span>
      <span>API Reference</span>
    </nav>

    <h1 class="doc-h1">API Reference</h1>
    <p class="doc-lead">Complete reference for all exported functions and types.</p>

    <section id="input">
      <h2 class="doc-h2"><code class="doc-code">input(value)</code></h2>
      <p class="doc-p">Creates a leaf input node. External code sets the value.</p>

      <h3 class="doc-h3">Signature</h3>
      <CodeBlock
        lang="typescript"
        code={`function input<T>(value: T): InputNode<T>`}
      />

      <h3 class="doc-h3">Parameters</h3>
      <table class="param-table">
        <thead>
          <tr><th>Parameter</th><th>Type</th><th>Description</th></tr>
        </thead>
        <tbody>
          <tr><td><code class="doc-code">value</code></td><td><code class="doc-code">T</code></td><td>Initial value of any type</td></tr>
        </tbody>
      </table>

      <h3 class="doc-h3">Returns</h3>
      <p class="doc-p">An <code class="doc-code">InputNode&lt;T&gt;</code> with methods:</p>
      <ul class="doc-ul">
        <li><code class="doc-code">get(): T</code> — returns current value</li>
        <li><code class="doc-code">set(value: T): void</code> — updates value, marks dependents dirty</li>
        <li><code class="doc-code">invalidate(): void</code> — forces invalidation of dependents</li>
        <li><code class="doc-code">isDirty(): false</code> — inputs are never dirty</li>
        <li><code class="doc-code">inspect(): InspectInfo</code> — debug information</li>
        <li><code class="doc-code">dispose(): void</code> — disconnect from graph</li>
      </ul>

      <h3 class="doc-h3">Example</h3>
      <CodeBlock
        filename="input-example.ts"
        lang="typescript"
        code={`const width = input(800)
width.get()     // 800
width.set(600)  // marks dependents dirty`}
      />
    </section>

    <section id="node">
      <h2 class="doc-h2"><code class="doc-code">node(options)</code></h2>
      <p class="doc-p">Creates a computed node with declared dependencies. Lazy evaluation, cached results.</p>

      <h3 class="doc-h3">Signature</h3>
      <CodeBlock
        lang="typescript"
        code={`function node<DependsOn extends Record<string, Node<any>>, R>(
  options: {
    dependsOn: DependsOn
    compute: (values: ResolvedValues<DependsOn>) => R
  }
): ComputedNode<R>`}
      />

      <h3 class="doc-h3">Options</h3>
      <table class="param-table">
        <thead>
          <tr><th>Property</th><th>Type</th><th>Description</th></tr>
        </thead>
        <tbody>
          <tr><td><code class="doc-code">dependsOn</code></td><td><code class="doc-code">Record&lt;string, Node&gt;</code></td><td>Map of names to dependency nodes</td></tr>
          <tr><td><code class="doc-code">compute</code></td><td><code class="doc-code">(values) => R</code></td><td>Function that computes the result from resolved dependency values</td></tr>
        </tbody>
      </table>

      <h3 class="doc-h3">Returns</h3>
      <p class="doc-p">A <code class="doc-code">ComputedNode&lt;R&gt;</code> with methods:</p>
      <ul class="doc-ul">
        <li><code class="doc-code">get(): R</code> — returns cached value or recomputes if dirty</li>
        <li><code class="doc-code">isDirty(): boolean</code> — true if any dependency changed</li>
        <li><code class="doc-code">invalidate(): void</code> — forces recompute on next get()</li>
        <li><code class="doc-code">inspect(): InspectInfo</code> — debug information</li>
        <li><code class="doc-code">dispose(): void</code> — disconnect from graph</li>
      </ul>

      <h3 class="doc-h3">Example</h3>
      <CodeBlock
        filename="node-example.ts"
        lang="typescript"
        code={`const width = input(800)
const height = input(600)

const area = node({
  dependsOn: { w: width, h: height },
  compute: ({ w, h }) => w * h
})

area.get()    // 480000
area.get()    // 480000 (cached)
width.set(1000)
area.get()    // 600000 (recomputed)`}
      />

      <Callout type="danger">
        <p>The <code class="doc-code">compute</code> function must be <strong>pure</strong>. No side effects. It may be called multiple times or not at all depending on cache state.</p>
      </Callout>
    </section>

    <section id="batch">
      <h2 class="doc-h2"><code class="doc-code">batch(fn)</code></h2>
      <p class="doc-p">Executes a function atomically. All input sets within the batch trigger a single invalidation walk. Returns the set of changed nodes.</p>

      <h3 class="doc-h3">Signature</h3>
      <CodeBlock
        lang="typescript"
        code={`function batch<T>(fn: () => T): T | Set<Node<any>>`}
      />

      <h3 class="doc-h3">Example</h3>
      <CodeBlock
        filename="batch-example.ts"
        lang="typescript"
        code={`const changed = batch(() => {
  width.set(1000)
  height.set(800)
})
// changed = Set of all dirtied nodes`}
      />
    </section>

    <section id="why">
      <h2 class="doc-h2"><code class="doc-code">why(node)</code></h2>
      <p class="doc-p">Traces the invalidation path for a node. Returns an array of node names from the target back to the source inputs that caused invalidation.</p>

      <h3 class="doc-h3">Signature</h3>
      <CodeBlock
        lang="typescript"
        code={`function why(node: Node<any>): string[]`}
      />

      <h3 class="doc-h3">Example</h3>
      <CodeBlock
        filename="why-example.ts"
        lang="typescript"
        code={`const cardHeight = node({
  dependsOn: { textHeight, padding },
  compute: ({ textHeight, padding }) => textHeight + padding
})

width.set(400)  // triggers textHeight recompute
why(cardHeight) // ['cardHeight', 'textHeight', 'width']`}
      />
    </section>

    <section id="ancestors-descendants">
      <h2 class="doc-h2"><code class="doc-code">ancestors(node)</code> / <code class="doc-code">descendants(node)</code></h2>
      <p class="doc-p">Navigate the dependency graph. <code class="doc-code">ancestors</code> returns all upstream dependencies. <code class="doc-code">descendants</code> returns all downstream dependents.</p>

      <h3 class="doc-h3">Signature</h3>
      <CodeBlock
        lang="typescript"
        code={`function ancestors(node: Node<any>): Set<Node<any>>
function descendants(node: Node<any>): Set<Node<any>>`}
      />

      <h3 class="doc-h3">Example</h3>
      <CodeBlock
        filename="graph-nav.ts"
        lang="typescript"
        code={`const a = input(1)
const b = node({ dependsOn: { a }, compute: ({ a }) => a * 2 })
const c = node({ dependsOn: { b }, compute: ({ b }) => b + 1 })

ancestors(c)   // Set { b, a }
descendants(a) // Set { b, c }`}
      />
    </section>

    <section id="todot">
      <h2 class="doc-h2"><code class="doc-code">toDot(nodes)</code></h2>
      <p class="doc-p">Exports the dependency graph as Graphviz DOT format for visualization.</p>

      <h3 class="doc-h3">Signature</h3>
      <CodeBlock
        lang="typescript"
        code={`function toDot(nodes: Node<any>[]): string`}
      />

      <h3 class="doc-h3">Example</h3>
      <CodeBlock
        filename="dot-example.ts"
        lang="typescript"
        code={`console.log(toDot([area]))
// Output:
// digraph G {
//   "width" -> "area"
//   "height" -> "area"
// }
// Paste to graphviz.online to visualize`}
      />
    </section>

    <section id="stats">
      <h2 class="doc-h2"><code class="doc-code">stats(nodes)</code></h2>
      <p class="doc-p">Returns statistics about the dependency graph.</p>

      <h3 class="doc-h3">Signature</h3>
      <CodeBlock
        lang="typescript"
        code={`function stats(nodes: Node<any[]>): {
  nodeCount: number
  inputCount: number
  computedCount: number
  edgeCount: number
  totalComputeCalls: number
}`}
      />

      <h3 class="doc-h3">Example</h3>
      <CodeBlock
        filename="stats-example.ts"
        lang="typescript"
        code={`stats([root])
// {
//   nodeCount: 5,
//   inputCount: 2,
//   computedCount: 3,
//   edgeCount: 4,
//   totalComputeCalls: 12
// }`}
      />
    </section>

    <section id="types">
      <h2 class="doc-h2">TypeScript Types</h2>

      <h3 class="doc-h3"><code class="doc-code">InputNode&lt;T&gt;</code></h3>
      <CodeBlock
        lang="typescript"
        code={`interface InputNode<T> {
  get(): T
  set(value: T): void
  invalidate(): void
  isDirty(): false
  inspect(): InspectInfo
  dispose(): void
}`}
      />

      <h3 class="doc-h3"><code class="doc-code">ComputedNode&lt;T&gt;</code></h3>
      <CodeBlock
        lang="typescript"
        code={`interface ComputedNode<T> {
  get(): T
  isDirty(): boolean
  invalidate(): void
  inspect(): InspectInfo
  dispose(): void
}`}
      />

      <h3 class="doc-h3"><code class="doc-code">InspectInfo</code></h3>
      <CodeBlock
        lang="typescript"
        code={`interface InspectInfo {
  id: string
  name: string
  type: 'input' | 'computed'
  value?: any
  dirty: boolean
  dependencyCount: number
  dependentCount: number
}`}
      />
    </section>

    <div class="page-nav">
      <a href="/docs/core-concepts">
        <span>←</span>
        <span>Core Concepts</span>
      </a>
      <a href="/docs/guides/virtualized-lists">
        <span>Guides</span>
        <span>→</span>
      </a>
    </div>
  </div>
</DocsLayout>

<style>
  .doc-page {
    max-width: 680px;
    padding: var(--sp-12) var(--sp-10);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-mono);
