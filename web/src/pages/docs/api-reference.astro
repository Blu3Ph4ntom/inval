    color: var(--fg);
    background: var(--bg-muted);
    padding: 3px 8px;
    border-radius: 6px;
    border: 1px solid var(--border);
    font-weight: 450;
    letter-spacing: 0.01em;
    transition: all var(--duration) var(--ease);
  }

  .doc-code:hover {
    background: var(--bg-elevated);
    border-color: var(--border-hover);
  }

  strong { color: var(--fg); font-weight: 500; }

