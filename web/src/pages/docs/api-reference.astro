  .doc-h2 .doc-code {
    font-size: var(--text-lg);
    background: none;
    padding: 0;
    color: var(--fg);
  }

  .doc-h3 {
    font-size: var(--text-base);
    font-weight: 600;
    margin-top: var(--sp-8);
    margin-bottom: var(--sp-3);
  }

