---
import DocsLayout from '../../layouts/DocsLayout.astro'
import DocsSidebar from '../../components/docs/DocsSidebar.astro'
import CodeBlock from '../../components/docs/CodeBlock.astro'
import Callout from '../../components/docs/Callout.astro'

const currentPage = '/docs/getting-started'
---

<DocsLayout title="Getting Started — Inval Docs" description="Install Inval and build your first dependency graph.">
  <DocsSidebar slot="sidebar" currentPage={currentPage} />

  <div class="doc-page">
    <nav class="breadcrumb">
      <a href="/docs/">Docs</a>
      <span class="bc-sep">/</span>
      <span>Getting Started</span>
    </nav>

    <h1 class="doc-h1">Getting Started</h1>
    <p class="doc-lead">Get up and running with Inval in under 5 minutes.</p>

    <section id="installation">
      <h2 class="doc-h2">Installation</h2>
      <p class="doc-p">Install via your preferred package manager:</p>

      <CodeBlock 
        lang="bash"
        code={`npm install @blu3ph4ntom/inval

# or
bun add @blu3ph4ntom/inval

# or
pnpm add @blu3ph4ntom/inval`}
      />

      <p class="doc-p">Or use the IIFE bundle directly in a script tag:</p>

      <CodeBlock 
        filename="index.html"
        lang="html"
        code={`<script src="https://unpkg.com/@blu3ph4ntom/inval/dist/inval.iife.js"><\/script>
<script>
  const { input, node, why } = Inval
  // ...
<\/script>`}
      />

      <Callout type="info">
        <p>Inval requires <strong>Node.js 18+</strong> and has <strong>zero runtime dependencies</strong>.</p>
      </Callout>
    </section>

    <section id="quick-start">
      <h2 class="doc-h2">Quick Start</h2>
      <p class="doc-p">Let's build a simple dependency graph. We'll compute the area of a rectangle and see how Inval handles changes.</p>

      <h3 class="doc-h3">Step 1: Import the API</h3>

      <CodeBlock 
        filename="step1.ts"
        lang="typescript"
        code={`import { input, node } from '@blu3ph4ntom/inval'`}
      />

      <h3 class="doc-h3">Step 2: Create input nodes</h3>
      <p class="doc-p">Input nodes are leaf nodes. They hold values that external code sets.</p>

      <CodeBlock 
        filename="step2.ts"
        lang="typescript"
        code={`const width = input(800)
const height = input(600)

width.get()   // 800
height.get()  // 600`}
      />

      <h3 class="doc-h3">Step 3: Create a computed node</h3>
      <p class="doc-p">Computed nodes declare their dependencies and compute lazily.</p>

      <CodeBlock 
        filename="step3.ts"
        lang="typescript"
        code={`const area = node({
  dependsOn: { w: width, h: height },
  compute: ({ w, h }) => w * h
})

area.get()  // 480000 — computes on first access`}
      />

      <h3 class="doc-h3">Step 4: Change an input and observe</h3>

      <CodeBlock 
        filename="step4.ts"
        lang="typescript"
        code={`area.get()  // 480000 — cached, zero cost

width.set(1000)
area.get()  // 600000 — recomputes because width changed`}
      />

      <Callout type="tip">
        <p>The key insight: <code class="doc-code">area.get()</code> returns the cached value if nothing changed. It only recomputes when a dependency is dirty.</p>
      </Callout>
    </section>

    <section id="your-first-graph">
      <h2 class="doc-h2">Your First Graph</h2>
      <p class="doc-p">Let's build something more realistic — a dashboard layout with dependent widgets.</p>

      <CodeBlock 
        filename="dashboard.ts"
        lang="typescript"
        code={`import { input, node, batch } from '@blu3ph4ntom/inval'

// External inputs
const dashboardWidth = input(1200)
const sidebarWidth = input(300)

// Computed: content area width
const contentWidth = node({
  dependsOn: { dash: dashboardWidth, sidebar: sidebarWidth },
  compute: ({ dash, sidebar }) => dash - sidebar
})

// Computed: chart width (60% of content)
const chartWidth = node({
  dependsOn: { content: contentWidth },
  compute: ({ content }) => content * 0.6
})

// Computed: table width (40% of content)
const tableWidth = node({
  dependsOn: { content: contentWidth },
  compute: ({ content }) => content * 0.4
})

// Initial values
chartWidth.get()  // 540 (900 * 0.6)
tableWidth.get()  // 360 (900 * 0.4)

// Change sidebar — chart and table both update
sidebarWidth.set(400)
chartWidth.get()  // 480 (800 * 0.6)
tableWidth.get()  // 320 (800 * 0.4)

// Atomic update: change both at once
const changed = batch(() => {
  dashboardWidth.set(1400)
  sidebarWidth.set(350)
})
// changed = Set of all dirtied nodes`}
      />

      <Callout type="warning">
        <p>Always use <code class="doc-code">batch()</code> when setting multiple inputs at once. This ensures a single atomic update instead of cascading invalidations.</p>
      </Callout>
    </section>

    <div class="page-nav">
      <a href="/docs/">
        <span>←</span>
        <span>Introduction</span>
      </a>
      <a href="/docs/core-concepts">
        <span>Core Concepts</span>
        <span>→</span>
      </a>
    </div>
  </div>
</DocsLayout>

<style>
  .doc-page {
    max-width: 680px;
    padding: var(--sp-12) var(--sp-10);
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    margin-bottom: var(--sp-8);
  }

  .breadcrumb a { color: var(--fg-muted); transition: color var(--duration) var(--ease); }
  .breadcrumb a:hover { color: var(--fg-secondary); }
  .bc-sep { color: var(--fg-muted); opacity: 0.4; }

  .doc-h1 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: var(--sp-3);
  }

  .doc-lead {
    font-size: var(--text-lg);
    color: var(--fg-secondary);
    margin-bottom: var(--sp-10);
    line-height: 1.65;
  }

  .doc-h2 {
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-top: var(--sp-12);
    margin-bottom: var(--sp-4);
    padding-top: var(--sp-12);
    border-top: 1px solid var(--border);
  }

  .doc-h2:first-of-type { margin-top: var(--sp-8); padding-top: 0; border-top: none; }

  .doc-h3 {
    font-size: var(--text-base);
    font-weight: 600;
    margin-top: var(--sp-8);
    margin-bottom: var(--sp-3);
  }

  .doc-p {
    font-size: var(--text-base);
    color: var(--fg-secondary);
    line-height: 1.7;
    margin-bottom: var(--sp-4);
  }

  .doc-ul {
    list-style: none;
    margin-bottom: var(--sp-4);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .doc-ul li {
    font-size: var(--text-base);
    color: var(--fg-secondary);
    line-height: 1.6;
    padding-left: var(--sp-4);
    position: relative;
  }

  .doc-ul li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--fg-muted);
    font-size: var(--text-xs);
  }

  .doc-code {
    font-family: var(--font-mono);
    font-size: 0.88em;
    color: var(--fg);
    background: var(--bg-muted);
    padding: 1px 6px;
    border-radius: 4px;
  }

  strong { color: var(--fg); font-weight: 500; }

  /* Page nav */
  .page-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--sp-16);
    padding-top: var(--sp-6);
    border-top: 1px solid var(--border);
  }

  .page-nav a {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--text-sm);
    color: var(--fg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: var(--sp-2) var(--sp-4);
    transition: color var(--duration) var(--ease), border-color var(--duration) var(--ease);
  }

  .page-nav a:hover { color: var(--fg); border-color: var(--border-hover); }

  @media (max-width: 960px) {
    .doc-page { padding: var(--sp-8) var(--sp-5); }
  }
</style>
