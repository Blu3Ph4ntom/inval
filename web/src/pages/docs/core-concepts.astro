  .breadcrumb a:hover { color: var(--fg-secondary); }
  .bc-sep { color: var(--fg-muted); opacity: 0.4; }

  .doc-h1 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: var(--sp-3);
  }

