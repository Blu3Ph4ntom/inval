---
export interface Props {
  code: string
  filename?: string
  lang?: string
}
const { code, filename, lang } = Astro.props
---

<div class="codeblock" x-data="{ copied: false }">
  {(filename || lang) && (
    <div class="codeblock-bar">
      {filename && <span class="codeblock-file">{filename}</span>}
      <button
        class="codeblock-copy"
        @click={`navigator.clipboard.writeText(${JSON.stringify(code)}); copied = true; setTimeout(() => copied = false, 2000)`}
      >
        <span x-show="!copied">copy</span>
        <span x-show="copied" style="color:var(--fg)">copied</span>
      </button>
    </div>
  )}
  <pre><code>{code}</code></pre>
</div>

<style>
  .codeblock {
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    margin: var(--sp-5) 0;
  }

  .codeblock-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--sp-2) var(--sp-4);
    border-bottom: 1px solid var(--border);
    background: var(--bg-muted);
  }

  .codeblock-file {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
  }

  .codeblock-copy {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: color var(--duration) var(--ease);
  }

  .codeblock-copy:hover { color: var(--fg-secondary); }

  .codeblock pre {
    padding: var(--sp-5);
    overflow-x: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }

  .codeblock code {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1.8;
    color: var(--fg-secondary);
    white-space: pre;
  }
</style>
