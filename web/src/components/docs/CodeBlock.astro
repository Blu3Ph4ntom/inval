---
import { Code } from "astro:components";

export interface Props {
  code: string;
  filename?: string;
  lang?: any;
}

const { code, filename, lang = "typescript" } = Astro.props;
const codeId = `code-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="code-block" id={codeId} x-data="{ copied: false }">
  <div class="code-header">
    <div class="code-header-left">
      {filename && <span class="code-filename">{filename}</span>}
      <span class="code-lang">{lang.toUpperCase()}</span>
    </div>
    <button
      class="code-copy"
      :class="{ 'is-copied': copied }"
      @click={`navigator.clipboard.writeText(document.getElementById('${codeId}').querySelector('code').innerText).then(() => { copied = true; setTimeout(() => copied = false, 2000) })`}
    >
      <span class="copy-icon" x-show="!copied">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
          ></path>
        </svg>
      </span>
      <span class="copy-icon success" x-show="copied">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </span>
      <span x-text="copied ? 'Copied' : 'Copy'"></span>
    </button>
  </div>
  <Code code={code.trim()} lang={lang} theme="github-dark" />
</div>

<style is:global>
  .code-block {
    background: #0d1117; /* GitHub Dark default for seamless blending */
    border: 1px solid #30363d;
    border-radius: 12px;
    overflow: hidden;
    margin: 2rem 0;
    font-family: "Geist Mono", "JetBrains Mono", "SF Mono", monospace;
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
  }

  .code-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1.25rem;
    background: #161b22;
    border-bottom: 1px solid #30363d;
  }

  .code-header-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .code-filename {
    font-size: 13px;
    color: #c9d1d9;
    font-weight: 500;
  }

  .code-lang {
    font-size: 10px;
    font-weight: 700;
    color: #8b949e;
    background: #21262d;
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .code-copy {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.75rem;
    background: #21262d;
    border: 1px solid #30363d;
    border-radius: 6px;
    cursor: pointer;
    font-size: 11px;
    font-weight: 600;
    color: #c9d1d9;
    transition: all 0.2s ease;
  }

  .code-copy:hover {
    background: #30363d;
    border-color: #8b949e;
  }

  .code-copy.is-copied {
    background: rgba(46, 160, 67, 0.15);
    border-color: #2ea043;
    color: #3fb950;
  }

  .copy-icon {
    width: 14px;
    height: 14px;
  }

  .code-block pre {
    display: contents;
    margin: 0 !important;
    padding: 0 !important;
    background: transparent !important;
    background-color: transparent !important;
    border: 0 !important;
    border-radius: 0 !important;
    box-shadow: none !important;
    width: 100%;
    font-size: 13.5px !important;
    line-height: 1.7 !important;
    overflow-x: auto;
  }

  .code-block code {
    display: grid;
    counter-reset: line;
    padding: 1.5rem 0;
  }

  .code-block .line {
    padding: 0 1.25rem;
    border-left: 3px solid transparent;
  }

  .code-block .line::before {
    counter-increment: line;
    content: counter(line);
    display: inline-block;
    width: 2rem;
    margin-right: 1.5rem;
    text-align: right;
    color: #484f58;
    user-select: none;
    font-size: 12px;
  }

  .code-block .line:hover {
    background: #161b22;
  }
</style>
