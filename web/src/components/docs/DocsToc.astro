---
export interface Props {
  headings: Array<{ id: string; text: string; level: number }>
  currentPage?: string
}
const { headings, currentPage = '' } = Astro.props

const resources = [
  { label: 'GitHub Repository', href: 'https://github.com/Blu3Ph4ntom/inval', icon: 'github' },
  { label: 'npm Package', href: 'https://npmjs.com/package/@blu3ph4ntom/inval', icon: 'npm' },
  { label: 'Report an Issue', href: 'https://github.com/Blu3Ph4ntom/inval/issues', icon: 'issue' },
]

const navLinks = [
  { label: 'Introduction', href: '/docs/', section: 'Getting Started' },
  { label: 'Installation', href: '/docs/getting-started#installation', section: 'Getting Started' },
  { label: 'Quick Start', href: '/docs/getting-started#quick-start', section: 'Getting Started' },
  { label: 'API Reference', href: '/docs/api-reference', section: 'Reference' },
]

function active(href: string) {
  return currentPage === href || (href !== '/docs/' && currentPage.startsWith(href.split('#')[0]))
}
---

<aside class="toc">
  <div class="toc-section">
    <p class="toc-label">On this page</p>
    <nav class="toc-nav">
      {headings.length > 0 ? (
        headings.map(h => (
          <a href={`#${h.id}`} class:list={['toc-link', { [`toc-h${h.level}`]: true }]}>
            {h.text}
          </a>
        ))
      ) : (
        <p class="toc-empty">No headings on this page</p>
      )}
    </nav>
  </div>

  <div class="toc-divider"></div>

  <div class="toc-section">
    <p class="toc-label">Quick Links</p>
    <nav class="toc-nav">
      {navLinks.map(link => (
        <a href={link.href} class:list={['toc-link', 'toc-nav-link', { 'is-active': active(link.href) }]}>
          {link.label}
        </a>
      ))}
    </nav>
  </div>

  <div class="toc-divider"></div>

  <div class="toc-section">
    <p class="toc-label">Resources</p>
    <div class="toc-resources">
      {resources.map(resource => (
        <a href={resource.href} target="_blank" rel="noopener noreferrer" class="toc-resource">
          <span class="resource-icon">
            {resource.icon === 'github' && (
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            )}
            {resource.icon === 'npm' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                <line x1="12" y1="22.08" x2="12" y2="12"/>
              </svg>
            )}
            {resource.icon === 'issue' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            )}
          </span>
          <span class="resource-label">{resource.label}</span>
          <span class="resource-arrow">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>

  <div class="toc-divider"></div>

  <div class="toc-section">
    <p class="toc-label">Helpful Guides</p>
    <div class="toc-links-grid">
      <a href="/docs/guides/debugging" class="toc-utility-link">
        <span class="utility-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </span>
        <span>Debugging Guide</span>
      </a>
      <a href="/docs/api-reference#types" class="toc-utility-link">
        <span class="utility-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>
        </span>
        <span>TypeScript Types</span>
      </a>
    </div>
  </div>
</aside>

<style>
  .toc {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: var(--sp-8) var(--sp-6);
  }

  .toc-section {
    padding: var(--sp-4) 0;
  }

  .toc-label {
    font-size: 10px;
    font-weight: 700;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: var(--sp-4);
    padding-left: var(--sp-2);
  }

  .toc-nav {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .toc-link {
    display: block;
    font-size: 13px;
    color: var(--fg-secondary);
    padding: 6px var(--sp-2);
    line-height: 1.5;
    border-radius: var(--radius-sm);
    transition: all 150ms var(--ease);
    border-left: 2px solid transparent;
  }

  .toc-link:hover {
    color: var(--fg);
    background: rgba(255, 255, 255, 0.03);
  }

  .toc-link.is-active {
    color: var(--fg);
    border-left-color: var(--green);
    background: rgba(0, 204, 136, 0.05);
  }

  .toc-h3 {
    padding-left: var(--sp-5);
    font-size: 12px;
    color: var(--fg-muted);
  }

  .toc-empty {
    font-size: 12px;
    color: var(--fg-muted);
    opacity: 0.5;
    padding: var(--sp-2);
    font-style: italic;
  }

  .toc-divider {
    height: 1px;
    background: linear-gradient(90deg, var(--border) 0%, transparent 100%);
    margin: var(--sp-2) 0;
  }

  .toc-nav-link {
    font-size: 13px;
    color: var(--fg-secondary);
  }

  .toc-nav-link.is-active {
    background: var(--bg-elevated);
    border-left-color: var(--fg-muted);
    color: var(--fg);
  }

  .toc-resources {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .toc-resource {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: 8px var(--sp-2);
    border-radius: var(--radius-sm);
    color: var(--fg-secondary);
    transition: all 150ms var(--ease);
  }

  .toc-resource:hover {
    color: var(--fg);
    background: rgba(255, 255, 255, 0.03);
  }

  .resource-icon {
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--fg-muted);
  }

  .toc-resource:hover .resource-icon {
    color: var(--fg-secondary);
  }

  .resource-icon svg {
    width: 100%;
    height: 100%;
  }

  .resource-label {
    flex: 1;
    font-size: 13px;
  }

  .resource-arrow {
    width: 12px;
    height: 12px;
    opacity: 0;
    transform: translate(-2px, 2px);
    transition: all 200ms var(--ease);
    color: var(--fg-muted);
  }

  .resource-arrow svg {
    width: 100%;
    height: 100%;
  }

  .toc-resource:hover .resource-arrow {
    opacity: 0.6;
    transform: translate(0, 0);
  }

  .toc-links-grid {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .toc-utility-link {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: 8px var(--sp-2);
    border-radius: var(--radius-sm);
    font-size: 13px;
    color: var(--fg-secondary);
    transition: all 150ms var(--ease);
  }

  .toc-utility-link:hover {
    color: var(--fg);
    background: rgba(255, 255, 255, 0.03);
  }

  .utility-icon {
    width: 16px;
    height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--fg-muted);
  }

  .utility-icon svg {
    width: 100%;
    height: 100%;
  }

  @media (max-width: 1200px) {
    .toc { display: none; }
  }
</style>
