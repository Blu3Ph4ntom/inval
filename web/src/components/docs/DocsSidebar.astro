---
export interface Props {
  currentPage: string
}
const { currentPage } = Astro.props

const nav = [
  {
    group: 'Getting Started',
    items: [
      { label: 'Introduction', href: '/docs/' },
      { label: 'Installation', href: '/docs/getting-started#installation' },
      { label: 'Quick Start', href: '/docs/getting-started#quick-start' },
    ]
  },
  {
    group: 'Core Concepts',
    items: [
      { label: 'Dependency Graphs', href: '/docs/core-concepts#dependency-graphs' },
      { label: 'Input Nodes', href: '/docs/core-concepts#input-nodes' },
      { label: 'Computed Nodes', href: '/docs/core-concepts#computed-nodes' },
      { label: 'Caching & Dirty', href: '/docs/core-concepts#caching' },
      { label: 'Batch Updates', href: '/docs/core-concepts#batch' },
      { label: 'Lifecycle', href: '/docs/core-concepts#lifecycle' },
    ]
  },
  {
    group: 'API Reference',
    items: [
      { label: 'input()', href: '/docs/api-reference#input' },
      { label: 'node()', href: '/docs/api-reference#node' },
      { label: 'batch()', href: '/docs/api-reference#batch' },
      { label: 'why()', href: '/docs/api-reference#why' },
      { label: 'ancestors() / descendants()', href: '/docs/api-reference#ancestors-descendants' },
      { label: 'toDot()', href: '/docs/api-reference#todot' },
      { label: 'stats()', href: '/docs/api-reference#stats' },
      { label: 'TypeScript Types', href: '/docs/api-reference#types' },
    ]
  },
  {
    group: 'Guides',
    items: [
      { label: 'Virtualized Lists', href: '/docs/guides/virtualized-lists' },
      { label: 'Dashboards', href: '/docs/guides/dashboards' },
      { label: 'React Integration', href: '/docs/guides/react-integration' },
      { label: 'Debugging', href: '/docs/guides/debugging' },
    ]
  },
  {
    group: 'Examples',
    items: [
      { label: 'Overview', href: '/docs/examples/' },
    ]
  },
]

function active(href: string) {
  return currentPage === href || (href !== '/docs/' && currentPage.startsWith(href.split('#')[0]))
}
---

<div class="sidebar">
  <div class="sidebar-header">
    <a href="/" class="sidebar-brand" aria-label="Inval Home">
      <img src="/logo.svg" alt="inval" class="sidebar-logo" width="90" height="20" />
    </a>
    <span class="sidebar-version">v0.1.1</span>
  </div>

  <nav class="sidebar-nav">
    {nav.map(section => (
      <div class="sidebar-group">
        <p class="sidebar-group-label">{section.group}</p>
        <ul class="sidebar-items">
          {section.items.map(item => (
            <li>
              <a
                href={item.href}
                class:list={['sidebar-link', { 'is-active': active(item.href) }]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>
</div>

<style>
  .sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--sp-8);
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: var(--sp-4);
    border-bottom: 1px solid var(--border);
  }

  .sidebar-brand {
    display: flex;
    align-items: center;
    text-decoration: none;
    transition: opacity var(--duration) var(--ease);
  }

  .sidebar-brand:hover {
    opacity: 0.8;
  }

  .sidebar-logo {
    display: block;
    height: 18px;
    width: auto;
    filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.05));
  }

  .sidebar-version {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--fg-muted);
    background: rgba(255, 255, 255, 0.05);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: var(--sp-8);
  }

  .sidebar-group {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .sidebar-group-label {
    font-size: 10px;
    font-weight: 700;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0 var(--sp-2);
    margin-bottom: var(--sp-2);
  }

  .sidebar-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }

  .sidebar-link {
    display: block;
    font-size: 13px;
    color: var(--fg-secondary);
    padding: 6px var(--sp-2);
    border-radius: var(--radius-sm);
    transition: all var(--duration) var(--ease);
  }

  .sidebar-link:hover {
    color: var(--fg);
    background: rgba(255, 255, 255, 0.03);
  }

  .sidebar-link.is-active {
    color: var(--fg);
    font-weight: 500;
    background: var(--bg-elevated);
  }
</style>
