<section class="section solution-section" id="solution">
  <div class="container">
    <div class="section-header fade-in">
      <span class="section-tag">// The Solution</span>
      <h2 class="section-title">Declare dependencies.<br /><span class="text-muted">The engine handles the rest.</span></h2>
    </div>
    
    <div class="solution-grid fade-in">
      <div class="code-block">
        <div class="code-header">
          <span class="code-filename">dashboard.ts</span>
          <span class="code-lang">TypeScript</span>
        </div>
        <pre><code class="syntax-highlighted">{`import { input, node, why } from '@blu3ph4ntom/inval'

// Declare inputs — external world feeds these
const width = input(800)
const height = input(600)

// Computed nodes — lazy, cached, incremental
const area = node({
  dependsOn: { w: width, h: height },
  compute: ({ w, h }) => w * h
})

area.get()    // 480000 — computes lazily
area.get()    // 480000 — cached, zero cost

width.set(1000)
area.get()    // 600000 — only recomputes if needed

why(area)     // ['area', 'width'] — debug invalidations`}</code></pre>
      </div>
      
      <div class="solution-benefits">
        <div class="benefit-item">
          <span class="benefit-icon">✓</span>
          <div>
            <h4>Caching</h4>
            <p>Returns cached value if deps haven't changed</p>
          </div>
        </div>
        <div class="benefit-item">
          <span class="benefit-icon">✓</span>
          <div>
            <h4>Incremental updates</h4>
            <p>Only recomputes what changed, not everything</p>
          </div>
        </div>
        <div class="benefit-item">
          <span class="benefit-icon">✓</span>
          <div>
            <h4>Debugging</h4>
            <p>why(node) traces exact invalidation path</p>
          </div>
        </div>
        <div class="benefit-item">
          <span class="benefit-icon">✓</span>
          <div>
            <h4>Zero dependencies</h4>
            <p>Pure TypeScript, 12KB packed</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .solution-section {
    padding: var(--space-4xl) 0;
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

