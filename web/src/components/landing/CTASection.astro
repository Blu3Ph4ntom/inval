---
import { withBase } from '../../utils/base'
---

<section class="cta-sect">
  <div class="wrap">
    <div class="cta-box" data-reveal>
      <p class="cta-kicker">Start building</p>
      <h2 class="cta-h">Deterministic layouts.<br />No guesswork.</h2>
      <p class="cta-sub">Drop inval into any project. Zero config, zero dependencies.</p>
      <div class="cta-actions">
        <a href={withBase('/docs/getting-started')} class="btn-solid">Read the docs</a>
        <a href="https://github.com/Blu3Ph4ntom/inval" target="_blank" rel="noopener" class="btn-ghost">View on GitHub</a>
      </div>
      <p class="cta-install" x-data="{ copied: false }">
        <code>npm i @blu3ph4ntom/inval</code>
        <button
          class="cta-copy"
          @click="navigator.clipboard.writeText('npm i @blu3ph4ntom/inval').then(() => { copied = true; setTimeout(() => copied = false, 2000); })"
          aria-label="Copy install command"
        >
          <svg x-show="!copied" class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
          <svg x-show="copied" class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
        </button>
      </p>
    </div>
  </div>
</section>

<style>
  .cta-sect {
    padding: var(--sp-24) 0;
    border-top: 1px solid var(--border);
  }

  .cta-box {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--sp-16) var(--sp-12);
    text-align: center;
    background: var(--bg-subtle);
  }

  .cta-kicker {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--sp-4);
  }

  .cta-h {
    font-size: clamp(var(--text-2xl), 5vw, var(--text-5xl));
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.04em;
    margin-bottom: var(--sp-4);
  }

  .cta-sub {
    font-size: var(--text-lg);
    color: var(--fg-secondary);
    margin-bottom: var(--sp-8);
  }

  .cta-actions {
    display: flex;
    justify-content: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-6);
    flex-wrap: wrap;
  }

  .btn-solid {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--accent-fg);
    background: var(--accent);
    padding: var(--sp-2) var(--sp-5);
    border-radius: var(--radius-sm);
    transition: opacity var(--duration) var(--ease);
  }

  .btn-solid:hover { opacity: 0.85; }

  .btn-ghost {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--fg-secondary);
    padding: var(--sp-2) var(--sp-5);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    transition: color var(--duration) var(--ease), border-color var(--duration) var(--ease);
  }

  .btn-ghost:hover { color: var(--fg); border-color: var(--border-hover); }

  .cta-install {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--fg-muted);
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .cta-install code {
    font-size: inherit;
    background: none;
  }

  .cta-copy {
    color: var(--fg-muted);
    background: none;
    border: none;
    cursor: pointer;
    padding: 2px;
    display: flex;
    align-items: center;
    transition: color 150ms var(--ease);
  }

  .cta-copy:hover {
    color: var(--fg-secondary);
  }

  .cta-copy:active {
    color: var(--green);
  }

  .copy-icon {
    width: 12px;
    height: 12px;
  }

  @media (max-width: 640px) {
    .cta-box { padding: var(--sp-12) var(--sp-6); }
    .cta-h br { display: none; }
  }
</style>
