{
  "name": "inval",
  "version": "0.1.0",
  "description": "Deterministic, incremental layout invalidation engine",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/inval.iife.js",
  "jsdelivr": "./dist/inval.iife.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./iife": "./dist/inval.iife.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --format esm --target node && bun build src/index.ts --outfile dist/index.cjs --format cjs --target node && bun build src/index.ts --outdir dist --format iife --global-name inval --target browser && bun run build:types",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "test": "bun test",
    "bench": "bun run bench/index.ts",
    "bench:compare": "bun run bench/compare.ts",
    "typecheck": "tsc --noEmit",
    "lint": "bunx biome check src/ test/",
    "demo:serve": "bun run demo/serve.ts",
    "prepublishOnly": "bun run typecheck && bun test && bun run build"
  },
  "keywords": [
    "layout",
    "invalidation",
    "dependency-graph",
    "reactive",
    "virtualization",
    "deterministic",
    "incremental",
    "dag",
    "computed",
    "memoization"
  ],
  "license": "MIT",
  "devDependencies": {
    "playwright": "^1.59.1",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/blu3ph4ntom/inval.git"
  },
  "homepage": "https://github.com/blu3ph4ntom/inval#readme",
  "bugs": {
    "url": "https://github.com/blu3ph4ntom/inval/issues"
  },
  "engines": {
    "node": ">=18"
  }
}
